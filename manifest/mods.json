{
  "$schema": "./mods.schema.json",
  "game": "skyrimspecialedition",
  "gamePath": "C:\\Steam\\steamapps\\common\\Skyrim Special Edition",
  "notes": "M1 essentials. Nexus-first (ADR 0005). File selection is runtime-dynamic (ADR 0006) — never pin fileIds.",
  "mods": [
    {
      "id": "root-builder",
      "name": "Root Builder",
      "category": "Tooling",
      "match": "Root Builder",
      "source": "nexus",
      "nexus": {
        "domain": "skyrimspecialedition",
        "modId": 31720,
        "url": "https://www.nexusmods.com/skyrimspecialedition/mods/31720"
      },
      "selection": {
        "platformAware": false,
        "matchGameVersion": false
      },
      "install": "mo2-mod",
      "required": true,
      "milestone": "M1",
      "notes": "Latest MAIN. MO2 plugin (tools/install-m1.ps1 extracts into mo2/plugins)."
    },
    {
      "id": "skse64",
      "name": "Skyrim Script Extender (SKSE64)",
      "category": "Script Extender & Core",
      "match": "SKSE64",
