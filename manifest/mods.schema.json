{
  "$comment": "Informational schema for manifest/mods.json — not enforced at runtime yet.",
  "type": "object",
  "required": ["game", "mods"],
  "properties": {
    "game": { "type": "string" },
    "gamePath": { "type": "string" },
    "mods": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "source", "install"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "category": { "type": "string", "description": "Display category for the web showcase." },
          "match": { "type": "string", "description": "Case-insensitive key linking a modlist.txt entry to this catalog record." },
          "source": { "enum": ["nexus", "silverlock", "github", "manual"] },
          "install": { "enum": ["mo2-mod", "root-builder-or-root-mod", "manual"] },
          "required": { "type": "boolean" },
          "milestone": { "type": "string" }
        }
      }
    }
  }
}
